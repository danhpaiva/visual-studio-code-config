{
	// --- Interface e Produtividade Geral ---
	"workbench.colorTheme": "Dark Modern",
	"workbench.iconTheme": "material-icon-theme",
	"workbench.sideBar.location": "right",
	"workbench.statusBar.visible": true,
	"workbench.startupEditor": "none",
	"window.menuBarVisibility": "compact",
	"window.zoomLevel": 0,
	"breadcrumbs.enabled": true,
	"explorer.compactFolders": false,
	"explorer.confirmDelete": false,
	"explorer.excludeGitIgnore": true,
	"workbench.editor.enablePreview": false, // Evita fechar abas acidentalmente
	// --- Editor e Tipografia (Otimizado para .NET/C#) ---
	"editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', Consolas",
	"editor.fontSize": 13,
	"editor.letterSpacing": 1.2,
	"editor.lineHeight": 24,
	"editor.fontLigatures": false,
	"editor.tabSize": 4, // Padrão C# / .NET
	"editor.renderLineHighlight": "gutter",
	"editor.renderWhitespace": "selection",
	"editor.minimap.enabled": false,
	"editor.bracketPairColorization.enabled": true,
	"editor.guides.bracketPairs": "active",
	"editor.rulers": [
		80,
		120
	],
	// --- Sugestões e Inteligência ---
	"editor.suggestSelection": "first",
	"editor.suggest.showMethods": true,
	"editor.acceptSuggestionOnEnter": "on", //smart
	"editor.semanticHighlighting.enabled": true,
	// --- Automação e Formatação (Clean Code) ---
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.organizeImports": "explicit",
		"source.fixAll": "explicit"
	},
	"extensions.autoUpdate": "onlyEnabledExtensions",
	"files.autoSave": "onFocusChange",
	// --- Git ---
	"git.enableSmartCommit": true,
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.confirmNoVerifyCommit": true,
	// --- Terminal Integrado ---
	"terminal.integrated.defaultLocation": "view",
	"terminal.integrated.cursorStyle": "underline",
	"terminal.integrated.enablePersistentSessions": false,
	"terminal.integrated.fontSize": 12,
	"terminal.integrated.fontFamily": "'Cascadia Mono', 'JetBrains Mono', Consolas",
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.scrollback": 10000,
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.profiles.windows": {
		"PowerShell": {
			"source": "PowerShell",
			"icon": "terminal-powershell",
			"args": [
				"-NoLogo"
			]
		},
		"Git Bash": {
			"source": "Git Bash"
		}
	},
	// --- Outros (Docker, XML, SQL, Telemetria) ---
	"docker.extension.enableComposeLanguageServer": false,
	"telemetry.telemetryLevel": "off",
	"redhat.telemetry.enabled": false,
	"codesnap.transparentBackground": true,
	"codesnap.showWindowTitle": true,
	"codesnap.containerPadding": "0.1em",
	"security.workspace.trust.untrustedFiles": "newWindow",
	"update.mode": "manual",
	"update.enableWindowsBackgroundUpdates": true,
	"update.showReleaseNotes": false,
	"mssql.connectionGroups": [
		{
			"name": "ROOT",
			"id": "ROOT"
		}
	],
	"xml.symbols.maxItemsComputed": 50000,
	"xml.server.vmargs": "-Xmx128M",
}
